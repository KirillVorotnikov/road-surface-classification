# Add patterns of files which you don't want to check into DVC storage.
# More info at https://dvc.org/doc/user-guide/dvcignore

# DVC files
.dvc/
.dvcignore

# Git files
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# Cache
__pycache__/
*.pyc
.pytest_cache/

# DVC cache directory
.dvc/cache
